	(text "Charger Safety pulls low when good, floats when bad\n\n"
		(exclude_from_sim no)
		(at 73.914 94.996 0)
		(effects
			(font
				(size 1.27 1.27)
			)
		)
		(uuid "3392aeb5-2099-4443-b3f5-11219abba660")
	)
	(text "When Charge Power Pin on BMS gets +12V, BMS goes into\nCharge Mode. Pushing the Charger Initialization button\ncloses the relay and powers Charge Power.\n\nOnce BMS finishes safety checks (and all check out good),\nthen Charger Safety pulls low.\n\nThe button may be released, and the relay will stay closed\nas long as Charger Safety remains low, which keeps Charge Power\nhigh and allows BMS to maintain Charge Mode.\n "
		(exclude_from_sim no)
		(at 79.502 53.086 0)
		(effects
			(font
				(size 1.27 1.27)
			)
		)
		(uuid "85923163-e42a-4ccd-87b1-1fc24d7615db")
	)
	(text "BMS to Charger CAN is required to control Charger output\n"
		(exclude_from_sim no)
		(at 77.724 65.786 0)
		(effects
			(font
				(size 1.27 1.27)
			)
		)
		(uuid "dbcfd5f1-7a16-4b0b-b959-797f13d2eab9")
	)
